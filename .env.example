# Nest server configuration (all values optional; defaults shown).
# Copy to `.env` and adjust. The binary reads these from the environment.

# Address the HTTP server binds to.
NEST_BIND_ADDR=127.0.0.1:8140

# Root directory for stored Eggs and the SQLite DB.
NEST_DATA_DIR=data

# SQLite database file path (defaults to {NEST_DATA_DIR}/nest.sqlite).
# NEST_DB_PATH=data/nest.sqlite

# Default Brood Limit (max Eggs kept per Clutch before pruning).
NEST_BROOD_LIMIT=10

# Secret used to sign/verify auth tokens (change in production!).
NEST_TOKEN_SECRET=dev-insecure-secret-change-me

# Token lifetime in seconds (default 7 days).
# NEST_TOKEN_EXPIRY_SECONDS=604800

# Tracing filter directive (e.g. info, debug, nest=debug).
NEST_LOG=info
